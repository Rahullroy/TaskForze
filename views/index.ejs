<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudentSprinter</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

     <% const today = new Date().toISOString().split('T')[0]; %>
    <header>
        <h1>StudentSprinter</h1>
        <h4>A Page Dedicated To Student Daily Tasks</h4>
        <p>Total Tasks: <%=totalTasks%></p>

        <p>Completed Tasks: <%=completedTasks%></p>

        <p>Pending Tasks: <%=pendingTasks%></p>
        <p>Today: <%=today%></p>

    </header>


    <div class="task-container">
        <form action="/add-task" method="post">
            <input type="text" name="task" placeholder="Enter Task Here">
            
            <br>
            <br>
            

            <label>
                DUE <input type="date" name="dueDate">
            </label>
            <br>
            <br>

            <select name="priority">
                <option value="Low">Low</option>
                <option value="Medium">Medium</option>
                <option value="High">High</option>
            </select>

           <button type="submit">add task here</button>
        </form>
    </div>

    <% tasks.forEach((task,index)=> { %>

        <div class="task-card">
            <br>

            


            <form action="/complete-task/<%=index%>" method="post">
                <input type="checkbox" name="Taskcompletion" onchange="this.form.submit()" <%= task.completed ? 'checked' : '' %>>
            </form>

            <% if(task.completed){ %>

                <s><%= task.task %></s>
                
            <% } else { %>

                <%= task.task %>

            <% } %>
                
            <br>
            <br>

            <% if(task.dueDate){ %>
                Due: <%= task.dueDate %>
            <% } %>
            
            <br>
           

            <% if(task.dueDate < today && !task.completed){ %>
                <p style="color:red;">⚠ Overdue</p>
            <% } %>


            <% if(task.priority== 'High'){ %>
                <p style="color:red;">HIGH</p>
            
            <% } else if(task.priority== 'Medium'){ %>
                <p style="color:rgba(232, 228, 13, 0.908);">MEDIUM</p>
    
            <% }else{ %>
                <p style="color:rgba(36, 164, 10, 0.908);">LOW</p>
            <% } %>
        
            

            <form action="/delete-task/<%=index%>" method="POST">
                <button type="submit">Delete</button>
            </form>
            <br>

            
                


           
            
        </div>
 
    <% }) %>





</body>
</html>