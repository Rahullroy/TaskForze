<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaskForge</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <% const today = new Date().toISOString().split('T')[0]; %>

    <header class="header">
        <div class="left">
            <h1>TaskForge</h1>
            <p>Organize and track your daily tasks efficiently</p>
        </div>
        <div class="right">
            <button id="darkbtn">🌙 Dark mode</button>
        </div>
    </header>

    <div class="app-shell">

        <aside class="ledger">
            <div class="ledger-eyebrow">Today's count</div>

            <div class="tally">
                <span class="num"><%= totalTasks %></span>
                <span class="label">📋 Total tasks</span>
            </div>

            <div class="tally done">
                <span class="num"><%= completedTasks %></span>
                <span class="label">✅ Completed</span>
            </div>

            <div class="tally pending">
                <span class="num"><%= pendingTasks %></span>
                <span class="label">⏳ Pending</span>
                <div class="progress-track">
                    <div class="progress-fill" style="width: <%= progressPercentage %>%"></div>
                </div>
                <div class="progress-caption">Progress: <%= Math.round(progressPercentage) %>%</div>
            </div>

            <form class="search-form" action="/" method="GET">
                <input type="text" name="search" placeholder="Search a task">
                <button type="submit">Go</button>
            </form>
        </aside>

        <main class="main-col">

            <p class="today-line">Today — <%= today %></p>

            <form class="add-card" action="/add-task" method="post">
                <input type="text" name="task" placeholder="What do you need to do?">

                <div class="field-row">
                    <div class="field">
                        <label for="dueDate">Due</label>
                        <input type="date" id="dueDate" name="dueDate">
                    </div>

                    <div class="field">
                        <label for="priority">Priority</label>
                        <select id="priority" name="priority">
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                        </select>
                    </div>

                    <button class="btn-ink" type="submit">Add task</button>
                </div>
            </form>

            <% if (tasks.length === 0) { %>
                <div class="empty-state">Nothing on the list yet — add your first task above.</div>
            <% } %>

            <div class="task-list">
            <% tasks.forEach((task) => { %> <% const priorityClass = task.priority === 'High' ? 'high' : (task.priority === 'Medium' ? 'medium' : 'low'); %>
                <% const isOverdue = task.dueDate < today && !task.completed; %>

                <div class="task-card">
                    <div class="task-tab <%= priorityClass %>">
                        <span><%= task.priority ? task.priority.toUpperCase() : 'MEDIUM' %></span>
                    </div>

                    <div class="task-body">

                        <% if (isOverdue) { %>
                            <span class="overdue-stamp">Overdue</span>
                        <% } %>

                        <div class="task-top">
                            <form class="check-form" action="/complete-task/<%=task._id%>" method="post">
                                <input type="checkbox" name="Taskcompletion" onchange="this.form.submit()" <%= task.completed ? 'checked' : '' %>>
                            </form>

                            <span class="task-text <%= task.completed ? 'is-done' : '' %>">
                                <%= task.task %>
                            </span>
                        </div>

                        <% if (task.dueDate) { %>
                            <div class="task-meta">
                                <span>Due <%= task.dueDate %></span>
                            </div>
                        <% } %>

                        <% if (task.editing) { %>
                            <form class="edit-row" action="/update-task/<%= task._id %>" method="post">
                                <input type="text" name="updatedTask" value="<%= task.task %>">
                                <button class="btn-ink" type="submit">Update</button>
                            </form>
                        <% } %>

                        <div class="task-actions">
                            <form action="/edit-task/<%= task._id %>" method="get">
                                <button class="link-btn" type="submit">Edit</button>
                            </form>

                            <form action="/delete-task/<%= task._id %>" method="POST">
                                <button class="link-btn danger" type="submit">Delete</button>
                            </form>
                        </div>

                    </div>
                </div>

            <% }) %>
            </div>

        </main>

    </div>

    <script>
        const btn = document.getElementById("darkbtn");
        btn.addEventListener("click", () => {
            document.body.classList.toggle("dark-mode");
        });
    </script>

</body>
</html>